(version 1)

# BEGIN COPPERBRAIN MANAGED RULES
# Generated from typed Copperbrain constraints; do not edit here.
(rule "Copperbrain_CB_HIGH_CURRENT"
  (condition "A.hasNetclass('CB_HIGH_CURRENT')")
  (constraint track_width (min 0.2mm) (opt 6.15mm))
  (constraint via_diameter (min 0.6mm))
  (constraint hole_size (min 0.3mm))
)
(rule "Copperbrain_CB_HIGH_CURRENT_clearance"
  (condition "A.hasNetclass('CB_HIGH_CURRENT') && A.Parent != B.Parent")
  (constraint clearance (min 0.2mm))
)
(rule "Copperbrain_CB_RS485"
  (condition "A.hasNetclass('CB_RS485')")
  (constraint track_width (min 0.2mm) (opt 0.2mm))
  (constraint via_diameter (min 0.6mm))
  (constraint hole_size (min 0.3mm))
  (constraint diff_pair_width (opt 0.25mm))
  (constraint diff_pair_gap (opt 0.25mm))
  (constraint length (max 200mm))
  (constraint diff_pair_uncoupled (max 15mm))
)
(rule "Copperbrain_CB_RS485_clearance"
  (condition "A.hasNetclass('CB_RS485') && A.Parent != B.Parent")
  (constraint clearance (min 0.2mm))
)
(rule "Copperbrain_CB_GATE_DRIVE"
  (condition "A.hasNetclass('CB_GATE_DRIVE')")
  (constraint track_width (min 0.2mm) (opt 0.3mm))
  (constraint via_diameter (min 0.6mm))
  (constraint hole_size (min 0.3mm))
  (constraint length (max 30mm))
)
(rule "Copperbrain_CB_GATE_DRIVE_clearance"
  (condition "A.hasNetclass('CB_GATE_DRIVE') && A.Parent != B.Parent")
  (constraint clearance (min 0.2mm))
)
