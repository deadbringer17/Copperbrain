  (constraint length (max 30mm))
)
(rule "Copperbrain_CB_KELVIN_SENSE_clearance"
  (condition "A.hasNetclass('CB_KELVIN_SENSE') && A.Parent != B.Parent")
  (constraint clearance (min 0.2mm))
)
