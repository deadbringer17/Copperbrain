(version 1)

# BEGIN COPPERBRAIN MANAGED RULES
# Generated from typed Copperbrain constraints; do not edit here.
# Copperbrain netclass-role CB_BOOST_INPUT high_current
(rule "Copperbrain_CB_BOOST_INPUT"
  (condition "A.hasNetclass('CB_BOOST_INPUT')")
  (constraint track_width (min 0.2mm) (opt 1.82mm))
  (constraint via_diameter (min 0.8mm))
  (constraint hole_size (min 0.4mm))
)
(rule "Copperbrain_CB_BOOST_INPUT_clearance"
  (condition "A.hasNetclass('CB_BOOST_INPUT') && A.Parent != B.Parent")
  (constraint clearance (min 0.25mm))
)
# Copperbrain netclass-role CB_BOOST_SWITCH switching
(rule "Copperbrain_CB_BOOST_SWITCH"
  (condition "A.hasNetclass('CB_BOOST_SWITCH')")
  (constraint track_width (min 0.2mm) (opt 1.5mm))
  (constraint via_diameter (min 0.8mm))
  (constraint hole_size (min 0.4mm))
  (constraint length (max 20mm))
)
(rule "Copperbrain_CB_BOOST_SWITCH_clearance"
  (condition "A.hasNetclass('CB_BOOST_SWITCH') && A.Parent != B.Parent")
  (constraint clearance (min 0.4mm))
)
# Copperbrain netclass-role CB_BOOST_48V high_voltage
(rule "Copperbrain_CB_BOOST_48V"
  (condition "A.hasNetclass('CB_BOOST_48V')")
  (constraint track_width (min 0.2mm) (opt 0.8mm))
  (constraint via_diameter (min 0.8mm))
  (constraint hole_size (min 0.4mm))
)
(rule "Copperbrain_CB_BOOST_48V_clearance"
  (condition "A.hasNetclass('CB_BOOST_48V') && A.Parent != B.Parent")
  (constraint clearance (min 0.5mm))
)
# Copperbrain netclass-role CB_BOOST_FEEDBACK signal
(rule "Copperbrain_CB_BOOST_FEEDBACK"
