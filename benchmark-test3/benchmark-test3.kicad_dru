  (constraint via_diameter (min 0.8mm))
  (constraint hole_size (min 0.4mm))
  (constraint length (max 25mm))
)
(rule "Copperbrain_CB_BOOST_FEEDBACK_clearance"
  (condition "A.hasNetclass('CB_BOOST_FEEDBACK') && A.Parent != B.Parent")
  (constraint clearance (min 0.2mm))
)
